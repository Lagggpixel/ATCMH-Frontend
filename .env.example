# Public runtime origins (safe to serialize; never put secrets in NEXT_PUBLIC_* variables)
FRONTEND_PUBLIC_ORIGIN=http://localhost:3000
DASHBOARD_API_URL=http://localhost:3001
# Compatibility alias for shared deployment inventories; Frontend reads DASHBOARD_API_URL.
DASHBOARD_AUTH_URL=http://localhost:3001

# Central Dashboard/Exams authentication
EXAMS_AUTH_KEY=
EXAMS_CSRF_SECRET=
EXAMS_LEARNER_SESSION_SECRET=

# Discord authorization
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_MENTOR_ROLE_IDS=
DISCORD_ADMIN_ROLE_IDS=
DISCORD_ADMIN_USER_IDS=
DISCORD_WEBHOOK_URL=

# Exams persistence and imports
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=atcmh_lms
IMPORT_IDEMPOTENCY_SECRET=
EXAMS_IMPORT_MAX_BYTES=5242880
EXAMS_IMPORT_PREVIEW_TTL_SECONDS=900
EXAMS_MANAGEMENT_WRITES_ENABLED=false

# Dashboard audit delivery
EXAMS_AUDIT_INGEST_URL=http://localhost:3001
EXAMS_AUDIT_INGEST_KEY=
